<mvc:View
    controllerName="com.sap.app.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    displayBlock="true"
    height="100%">

    <tnt:ToolPage id="toolPage">
        <tnt:header>
            <tnt:ToolHeader>
                <Button
                    id="sideNavToggleBtn"
                    icon="sap-icon://menu2"
                    press=".onSideNavToggle"
                    type="Transparent" />
                <Title text="{i18n>appHeaderTitle}" level="H4" />
                <ToolbarSpacer />
                <Label text="{i18n>appHeaderTech}" class="sapUiTinyMarginEnd" />
                <Button
                    id="chatToggleBtn"
                    icon="sap-icon://discussion"
                    press=".onChatToggle"
                    type="Transparent"
                    tooltip="{i18n>chatToggleTooltip}" />
                <Avatar initials="AI" displaySize="XS" backgroundColor="Accent6" />
            </tnt:ToolHeader>
        </tnt:header>

        <tnt:sideContent>
            <tnt:SideNavigation
                id="sideNavigation"
                selectedKey="{side>/selectedKey}"
                itemSelect=".onNavItemSelect">
                <tnt:NavigationList>
                    <tnt:NavigationListItem text="{i18n>navDashboard}" icon="sap-icon://home" key="dashboard" />
                    <tnt:NavigationListItem text="{i18n>navOrders}" icon="sap-icon://sales-order" key="orders" />
                    <tnt:NavigationListItem text="{i18n>navMaterials}" icon="sap-icon://product" key="materials" />
                    <tnt:NavigationListItem text="{i18n>navFinance}" icon="sap-icon://money-bills" key="finance" />
                </tnt:NavigationList>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <tnt:mainContents>
            <HBox height="100%" width="100%" renderType="Bare">
                <items>
                    <!-- Main content area — takes remaining space -->
                    <App id="appContainer">
                        <layoutData>
                            <FlexItemData growFactor="1" />
                        </layoutData>
                    </App>

                    <!-- AI Chat Panel (right side) -->
                    <Page
                        id="chatPanel"
                        visible="false"
                        showHeader="true"
                        backgroundDesign="Solid">
                        <layoutData>
                            <FlexItemData baseSize="380px" shrinkFactor="0" />
                        </layoutData>
                        <customHeader>
                            <Bar design="Header">
                                <contentLeft>
                                    <core:Icon src="sap-icon://da-2" class="sapUiSmallMarginBegin" />
                                    <Title text="{i18n>chatTitle}" level="H5" class="sapUiSmallMarginBegin" />
                                </contentLeft>
                                <contentRight>
                                    <Button icon="sap-icon://delete" press=".onClearChat" tooltip="{i18n>chatClearTooltip}" type="Transparent" />
                                    <Button icon="sap-icon://decline" press=".onChatToggle" tooltip="{i18n>chatCloseTooltip}" type="Transparent" />
                                </contentRight>
                            </Bar>
                        </customHeader>
                        <content>
                            <List
                                id="chatMessages"
                                items="{chat>/messages}"
                                noDataText="{i18n>chatNoData}"
                                growing="true"
                                growingScrollToLoad="true">
                                <CustomListItem type="Inactive">
                                    <VBox class="sapUiSmallMargin">
                                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                                            <Label text="{chat>role}" design="Bold" />
                                            <HBox alignItems="Center">
                                                <Button
                                                    icon="sap-icon://edit"
                                                    type="Transparent"
                                                    press=".onResendMessage"
                                                    tooltip="{i18n>chatResend}"
                                                    visible="{= ${chat>isUser} === true}" />
                                                <Label text="{chat>time}" design="Light" />
                                            </HBox>
                                        </HBox>
                                        <FormattedText htmlText="{chat>content}" class="sapUiTinyMarginTop" />
                                    </VBox>
                                </CustomListItem>
                            </List>
                        </content>
                        <footer>
                            <Toolbar class="chatInputToolbar" height="auto">
                                <VBox width="100%" class="sapUiTinyMargin">
                                    <TextArea
                                        id="chatInput"
                                        placeholder="{i18n>chatPlaceholder}"
                                        rows="3"
                                        width="100%"
                                        growing="true"
                                        growingMaxLines="6"
                                        class="sapUiTinyMarginBottom" />
                                    <HBox justifyContent="End" width="100%">
                                        <Button
                                            text="{i18n>chatSend}"
                                            icon="sap-icon://feeder-arrow"
                                            press=".onChatSend"
                                            type="Emphasized" />
                                    </HBox>
                                </VBox>
                            </Toolbar>
                        </footer>
                    </Page>
                </items>
            </HBox>
        </tnt:mainContents>
    </tnt:ToolPage>
</mvc:View>
