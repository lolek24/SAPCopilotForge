{
  "_version": "1.58.0",
  "sap.app": {
    "id": "com.sap.app",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {}
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.f": {},
        "sap.tnt": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.sap.app.i18n.i18n"
        }
      },
      "": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {}
      }
    },
    "rootView": {
      "viewName": "com.sap.app.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "com.sap.app.view",
        "controlAggregation": "pages",
        "controlId": "appContainer"
      },
      "routes": [
        {
          "name": "dashboard",
          "pattern": "",
          "target": ["dashboard"]
        },
        {
          "name": "orders",
          "pattern": "orders",
          "target": ["orders"]
        },
        {
          "name": "materials",
          "pattern": "materials",
          "target": ["materials"]
        },
        {
          "name": "finance",
          "pattern": "finance",
          "target": ["finance"]
        }
      ],
      "targets": {
        "dashboard": {
          "viewType": "XML",
          "viewName": "Dashboard"
        },
        "orders": {
          "viewType": "XML",
          "viewName": "Orders"
        },
        "materials": {
          "viewType": "XML",
          "viewName": "Materials"
        },
        "finance": {
          "viewType": "XML",
          "viewName": "Finance"
        }
      }
    }
  }
}
